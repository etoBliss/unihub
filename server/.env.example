PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<database_name>?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
ADMIN_API_KEY=your_admin_secret_key_here

# Nodemailer SMTP settings (e.g. Gmail App Passwords)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_16_char_app_password

# The URL where your frontend is deployed (e.g. https://unihub-client.vercel.app)
# Do NOT include a trailing slash!
CLIENT_URL=http://localhost:5173
